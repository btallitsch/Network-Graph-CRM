rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: is request from authenticated user?
    function isAuth() {
      return request.auth != null;
    }

    // Helper: does the document belong to the requesting user?
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Nodes collection
    match /nodes/{nodeId} {
      allow read: if isAuth() && isOwner(resource.data.userId);
      allow create: if isAuth() && isOwner(request.resource.data.userId);
      allow update: if isAuth() && isOwner(resource.data.userId);
      allow delete: if isAuth() && isOwner(resource.data.userId);
    }

    // Edges collection
    match /edges/{edgeId} {
      allow read: if isAuth() && isOwner(resource.data.userId);
      allow create: if isAuth() && isOwner(request.resource.data.userId);
      allow update: if isAuth() && isOwner(resource.data.userId);
      allow delete: if isAuth() && isOwner(resource.data.userId);
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
